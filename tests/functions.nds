-- functions.nds — Function declaration, calls, recursion, scope.

import "prelude.nds"

-- Basic function
function double(x)
    return x * 2
end function

assert double(21) = 42

-- Multiple arguments
function add(a, b)
    return a + b
end function

assert add(3, 4) = 7

-- Recursion
function factorial(n)
    if n <= 1 then
        return 1
    end if
    return n * factorial(n - 1)
end function

assert factorial(0) = 1
assert factorial(1) = 1
assert factorial(5) = 120
assert factorial(10) = 3628800

-- No explicit return gives nothing
function noReturn()
    set x to 42
end function

assert noReturn() = nothing

-- Functions are first-class values
set f to factorial
assert f(5) = 120

-- Too few arguments get nothing
function needsTwo(a, b)
    return b
end function

assert needsTwo(1) = nothing

-- Function with local variables
function localTest()
    my x is 10
    my y is 20
    return x + y
end function

assert localTest() = 30
